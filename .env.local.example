# Copy this file to .env.local and fill in your Supabase project values.
# Both are PUBLIC (safe to expose in the browser). Row Level Security on the
# `leads` table restricts the anon role to INSERT-only.
#
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# NEVER put the service-role key in a NEXT_PUBLIC_* variable — it would be
# exposed client-side. This site never needs it; read leads from the dashboard.
